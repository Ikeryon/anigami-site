---
import BaseLayout from './BaseLayout.astro';
import BrandHeader from '../components/BrandHeader.astro';

// Ogni landing di marchio è un manifesto autonomo (brief, sez. 5):
// si apre a piena altezza con il logo grande al centro e una sola riga
// di apertura — la frase più forte del racconto, non uno slogan.
// Poi la barra dei capitoli resta agganciata in alto per tutta la
// lettura: è la spina dorsale della navigazione interna.
//
// CROMIE (10/07/2026): ogni landing gioca sulla cromia del proprio
// marchio via `theme` (variabili CSS) e, per Tipicità, l'hero è un
// campo pieno di colore come la copertina della brochure TF27
// (heroVariant="field").

interface Chapter {
  id: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  accent: string;
  brandName: string;
  chapters: Chapter[];
  structuredData?: Record<string, unknown>;
  logoSrc?: string;
  /** Riga di apertura nell'hero — la frase-chiave del marchio. */
  heroLine?: string;
  /** Etichetta piccola sopra il logo: luogo, anno di nascita. */
  kicker?: string;
  /** Cromia della pagina (variabili CSS, vedi BaseLayout). */
  theme?: Record<string, string>;
  /** 'atmosphere' (default): alone del colore marchio sul fondo pagina.
      'field': campo pieno del colore marchio, stile copertina brochure. */
  heroVariant?: 'atmosphere' | 'field';
  /** Classe-gancio per gli stili specifici della pagina (es. 'v-tipicita'). */
  variant?: string;
}

const {
  title,
  description,
  accent,
  brandName,
  chapters,
  structuredData,
  logoSrc,
  heroLine,
  kicker,
  theme,
  heroVariant = 'atmosphere',
  variant = '',
} = Astro.props;

const heroClass = `brand-hero${heroVariant === 'field' ? ' brand-hero--field' : ''}${variant ? ` ${variant}` : ''}`;
---

<BaseLayout title={title} description={description} accent={accent} structuredData={structuredData} theme={theme}>
  <BrandHeader slot="header" />

  <section class={heroClass}>
    <h1 class="sr-only">{brandName}</h1>
    {kicker && <p class="eyebrow" data-reveal>{kicker}</p>}
    {logoSrc ? (
      <img class="hero-logo" src={logoSrc} alt={brandName} data-reveal />
    ) : (
      <span class="hero-mark" data-reveal>{brandName}</span>
    )}
    {heroLine && <p class="hero-line" data-reveal>{heroLine}</p>}
    <div class="scroll-cue" aria-hidden="true"></div>
  </section>

  <div class={`chapter-bar${variant ? ` ${variant}` : ''}`}>
    <div class="inner">
      {logoSrc && <img class="bar-logo" src={logoSrc} alt="" />}
      <nav aria-label={`Capitoli di ${brandName}`}>
        {chapters.map((c) => <a href={`#${c.id}`}>{c.label}</a>)}
      </nav>
      <a class="bar-home" href="/">Anigami</a>
    </div>
  </div>

  <main class={`container brand-main${variant ? ` ${variant}` : ''}`}>
    <div class="practical-info" data-reveal>
      <slot name="practical" />
    </div>

    <slot />
  </main>
</BaseLayout>
