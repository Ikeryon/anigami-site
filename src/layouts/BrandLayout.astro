---
import BaseLayout from './BaseLayout.astro';
import BrandHeader from '../components/BrandHeader.astro';

interface Chapter {
  id: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  accent: string;
  brandName: string;
  chapters: Chapter[];
  structuredData?: Record<string, unknown>;
}

const { title, description, accent, brandName, chapters, structuredData } = Astro.props;
---

<BaseLayout title={title} description={description} accent={accent} structuredData={structuredData}>
  <BrandHeader slot="header" brandName={brandName} />

  <main class="container">
    <h1 data-reveal>{brandName}</h1>

    <div class="practical-info" data-reveal>
      <slot name="practical" />
    </div>

    <nav class="chapter-nav" aria-label={`Capitoli di ${brandName}`}>
      {chapters.map((c) => <a class="trace-link" href={`#${c.id}`}>{c.label}</a>)}
    </nav>

    <slot />
  </main>
</BaseLayout>
