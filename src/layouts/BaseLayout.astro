---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  /** Colore accento del marchio per questa pagina (sovrascrive --brand-accent). */
  accent?: string;
  /** JSON-LD schema.org da iniettare invisibile in pagina (sezione 9bis del brief). */
  structuredData?: Record<string, unknown>;
}

const { title, description, accent, structuredData } = Astro.props;
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600&family=Manrope:wght@300;400;500&family=Inter:wght@300;400;500&display=swap"
    rel="stylesheet"
  />

  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  {structuredData && (
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  )}

  {accent && (
    <style set:html={`:root { --brand-accent: ${accent}; }`} />
  )}
</head>
<body>
  <Header />
  <slot />
  <Footer />
</body>
</html>
