---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImaginaHeader from '../components/ImaginaHeader.astro';

// NOTA PER PAOLO: l'hero punta a /hero-imagina.mp4 — il video che stai
// preparando. Finché non esiste, il browser semplicemente non mostra nulla
// lì (nessuna icona rotta) e resta visibile il gradiente di sfondo, quindi
// va già online in sicurezza anche senza il file. Basta caricare il video
// con questo nome in public/ quando è pronto, nessun'altra modifica.
//
// Il bordo irregolare che separa l'hero dal resto della pagina è un gesto
// disegnato a mano, non un'onda geometrica — eco della pennellata bianca
// del logo Imagina (brief, sez. 8).
//
// UPGRADE OSSATURA (10/07/2026): i quattro marchi non sono più card in
// griglia ma pannelli-manifesto a tutta larghezza, in sequenza — ognuno
// respira nel proprio colore e occupa la scena da solo: il sito è un
// contenitore di poster autonomi, e la home è il corridoio del cinema.
// Tra hero e pannelli, una sola dichiarazione di metodo.
// Le righe di testo sono bozze mie: sostituiscile con parole tue.

const brands = [
  {
    href: '/tipicita/',
    name: 'Tipicità',
    tagline: 'Il festival delle traiettorie indigene. Dal 1993, Fermo.',
    accent: '#035f6a',
  },
  {
    href: '/grand-tour-delle-marche/',
    name: 'Grand Tour delle Marche',
    tagline: 'Un laboratorio di comunità a geometria variabile. Dal 2015.',
    accent: '#ee726c',
  },
  {
    href: '/tipicita-in-blu/',
    name: 'Tipicità in Blu',
    tagline: 'Mare, laboratorio di futuro. Ancona.',
    accent: '#209fb6',
  },
  {
    href: '/evo/',
    name: 'EVO',
    tagline: 'I linguaggi del terzo millennio. Macerata.',
    accent: '#7f1244',
  },
];
---

<BaseLayout
  title="Imagina Srl Società Benefit"
  description="Imagina Srl Società Benefit: Tipicità, Grand Tour delle Marche, Tipicità in Blu, EVO — quattro festival, un unico metodo."
>
  <ImaginaHeader slot="header" />

  <section class="hero">
    <video
      class="hero-video"
      autoplay
      muted
      loop
      playsinline
      poster="/logo-imagina.svg"
    >
      <source src="/hero-imagina.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>

    <div class="hero-content">
      <p class="hero-kicker">Imagina · dal 1991, Camerino</p>
      <p class="hero-line">Quattro festival.<br />Un'unica rete che continua a muoversi.</p>
    </div>

    <svg class="hero-edge" viewBox="0 0 1440 100" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,40 C 60,10 130,55 210,35 C 300,12 360,60 460,38 C 560,15 610,58 700,40 C 800,20 860,62 960,36 C 1060,10 1120,58 1220,34 C 1310,14 1370,50 1440,30 L1440,100 L0,100 Z" />
    </svg>
  </section>

  <section class="manifesto">
    <p data-reveal>Non organizziamo eventi: coltiviamo reti.<br />Circa trecento realtà pubbliche e private, un unico metodo — e ogni festival che impara a camminare da solo.</p>
  </section>

  <section class="brand-panels" aria-label="I quattro festival">
    {brands.map((b, i) => (
      <a class="brand-panel" href={b.href} style={`--card-accent: ${b.accent}`} data-reveal>
        <div class="panel-inner">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <div class="panel-text">
            <h2>{b.name}</h2>
            <p>{b.tagline}</p>
          </div>
          <span class="go" aria-hidden="true">→</span>
        </div>
      </a>
    ))}
  </section>

  <section class="home-numbers">
    <div class="numbers">
      <div class="stat" data-reveal><strong>~300</strong><span>realtà pubbliche e private in rete</span></div>
      <div class="stat" data-reveal><strong>4</strong><span>festival, un unico metodo</span></div>
      <div class="stat" data-reveal><strong>1991</strong><span>l'anno in cui tutto comincia</span></div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 480px;
    overflow: hidden;
    background: radial-gradient(ellipse at 30% 20%, var(--imagina-grad-a) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 80%, var(--imagina-grad-b) 0%, transparent 55%),
      var(--bg-void);
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(5, 5, 7, 0.25) 0%, rgba(5, 5, 7, 0.55) 70%, var(--bg-void) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 0 1.6rem 5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero-kicker {
    font-family: 'Manrope', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin: 0 0 1rem;
  }

  .hero-line {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.9rem, 5vw, 3.4rem);
    line-height: 1.15;
    color: var(--text-soft);
    max-width: 16em;
    margin: 0;
  }

  .hero-edge {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    width: 100%;
    height: 60px;
    z-index: 3;
  }

  .hero-edge path {
    fill: var(--bg-void);
  }

  .manifesto {
    max-width: 880px;
    margin: 0 auto;
    padding: clamp(4rem, 10vw, 7rem) 1.6rem clamp(3rem, 8vw, 5.5rem);
    text-align: center;
  }

  .manifesto p {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 3.6vw, 2.4rem);
    line-height: 1.35;
    color: var(--text-soft);
    margin: 0;
  }

  /* --- I quattro pannelli-manifesto --- */
  .brand-panels {
    border-top: 1px solid var(--hairline);
  }

  .brand-panel {
    display: block;
    position: relative;
    text-decoration: none;
    border-bottom: 1px solid var(--hairline);
    overflow: hidden;
  }

  .brand-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 85% 120% at 12% 50%, color-mix(in srgb, var(--card-accent) 26%, transparent), transparent 65%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .brand-panel::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--card-accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.45s ease;
  }

  .brand-panel:hover::before,
  .brand-panel:focus-visible::before {
    opacity: 1;
  }

  .brand-panel:hover::after,
  .brand-panel:focus-visible::after {
    transform: scaleY(1);
    transform-origin: top;
  }

  .panel-inner {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(2.8rem, 7vw, 5rem) 1.6rem;
    display: flex;
    align-items: baseline;
    gap: clamp(1.2rem, 4vw, 2.6rem);
  }

  .num {
    font-family: 'Manrope', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: var(--text-faint);
    flex: none;
  }

  .panel-text {
    flex: 1;
    min-width: 0;
  }

  .brand-panel h2 {
    font-size: clamp(2.1rem, 6.5vw, 4.2rem);
    line-height: 1.02;
    color: var(--text-soft);
    margin: 0 0 0.45rem;
    transition: color 0.35s ease, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .brand-panel:hover h2,
  .brand-panel:focus-visible h2 {
    color: var(--card-accent);
    transform: translateX(0.35em);
  }

  .brand-panel p {
    font-family: 'Manrope', sans-serif;
    font-size: 0.88rem;
    color: var(--text-dim);
    margin: 0;
  }

  .go {
    font-family: 'Manrope', sans-serif;
    font-size: 1.4rem;
    color: var(--text-faint);
    flex: none;
    align-self: center;
    transition: color 0.35s ease, transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .brand-panel:hover .go,
  .brand-panel:focus-visible .go {
    color: var(--card-accent);
    transform: translateX(0.5em);
  }

  .home-numbers {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 4rem) 1.6rem 2rem;
  }

  .home-numbers .stat strong {
    font-size: clamp(2.4rem, 5vw, 3.4rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      display: none;
    }

    .brand-panel h2,
    .go {
      transition: none;
    }
  }
</style>
