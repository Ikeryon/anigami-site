---
import BrandLayout from '../../layouts/BrandLayout.astro';

// PAGINA-ECO DELLA BROCHURE TF27 — REVISIONE "ARIA" (11/07/2026):
// feedback di Paolo: troppa parete di testo, lettura pesante. La brochure
// respira perché alterna sempre testo breve, immagine e bianco. Quindi:
// - stessi testi lavorati insieme, MA spezzati in paragrafi brevi
//   (solo a cavallo di frasi, nessuna parola cambiata);
// - frasi-chiave estratte in grande corpo serif teal (.keyline);
// - placeholder-immagine intercalati NEL testo (float destra/sinistra),
//   non solo in fondo;
// - Trama = tre schede ariose in griglia, non tre blocchi in colonna;
// - Ingranaggi = nove etichette leggere, non un elenco in prosa;
// - corpo testo più grande e interlinea più generosa.
//
// ⚠️ DISCREPANZA DA RISOLVERE: brochure = 1991 (35ª edizione nel 2027);
// i nostri testi = 1993. In timeline seguo la brochure, nel testo resta
// 1993 — dimmi tu quale vale e uniformo.

const chapters = [
  { id: 'trama', label: 'Trama' },
  { id: 'essenza', label: 'Essenza' },
  { id: 'motore', label: 'Motore' },
  { id: 'tracce', label: 'Tracce' },
];

// Date confermate da Paolo (10/07/2026): edizione 2027, 12-13-14 marzo.
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: 'Tipicità Festival',
  startDate: '2027-03-12',
  endDate: '2027-03-14',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: {
    '@type': 'Place',
    name: 'Fermo',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Fermo',
      addressRegion: 'Marche',
      addressCountry: 'IT',
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Imagina Srl Società Benefit',
    url: 'https://anigami.it',
  },
};

// Cromia dalla brochure: interni bianchi, teal ufficiale come accento.
const theme = {
  '--bg-void': '#fcfcfa',
  '--bg-deep': '#eef4f4',
  '--bg-mid': '#e2eded',
  '--text-soft': '#1e2a2c',
  '--text-dim': 'rgba(30, 42, 44, 0.68)',
  '--text-faint': 'rgba(30, 42, 44, 0.44)',
  '--hairline': 'rgba(3, 95, 106, 0.16)',
};

const gears = [
  'Sviluppo territoriale',
  'Biodiversità e sostenibilità',
  'Turismo esperienziale',
  'Patrimonio enogastronomico e innovazione',
  'Manifattura creativa e Made in Italy',
  'Economia circolare e transizione verde',
  'Cooperazione accademica e ricerca',
  'Cultura digitale e comunità intelligenti',
  'Giovani e competenze per il futuro',
];

// Timeline delle Tracce — dati dalla brochure TF27.
const timeline = [
  { year: '1991', text: 'Festival dei prodotti tipici delle Marche — l’evento pionieristico', key: true },
  { year: '2011', text: 'Made in Marche Festival — turismo, moda e artigianato accanto all’enogastronomia', key: true },
  { year: '2015–16', text: 'Dubai, EAU — Italian Cuisine World Summit' },
  { year: '2017', text: 'Abu Dhabi, EAU — Italian Cuisine World Summit' },
  { year: '2018', text: 'New York, USA · Tirana e Valona, Albania' },
  { year: '2019', text: 'Ottawa e Montréal, Canada' },
  { year: '2022', text: 'Semplicemente "Festival" — ecosistema nazionale delle "micro-Italie" · EXPO2020 Dubai · Dar Es Salaam e Zanzibar, Tanzania', key: true },
  { year: '2023', text: 'Parigi, Francia — presentazione della candidatura Unesco della cucina italiana' },
  { year: '2024', text: 'Tokyo e Osaka, Giappone' },
  { year: '2025', text: 'EXPO2025 Osaka · Bahia Blanca, Buenos Aires e Ushuaia, Argentina' },
  { year: '2027', text: '35ª edizione — Fermo, 12–14 marzo', key: true },
];
---

<BrandLayout
  title="Tipicità Festival — Fermo, 12-14 marzo 2027"
  description="Tipicità Festival, Fermo, 12-14 marzo 2027: dal 1993 il festival delle traiettorie indigene tra enogastronomia, artigianato e cultura del territorio."
  accent="#035f6a"
  brandName="Tipicità Festival"
  chapters={chapters}
  structuredData={structuredData}
  logoSrc="/logos/tipicita.svg"
  kicker="Fermo · 12–14 marzo 2027"
  heroLine="Il festival delle traiettorie indigene. Racconta il globale attraverso il locale."
  theme={theme}
  heroVariant="field"
  variant="v-tipicita"
>
  <Fragment slot="practical">
    <span><strong>Quando</strong> 12–14 marzo 2027</span>
    <span><strong>Dove</strong> Fermo</span>
    <span><strong>Dal</strong> 1993</span>
  </Fragment>

  <section class="chapter" id="trama">
    <h2 data-reveal>Trama</h2>

    <div class="trama-grid">
      <article class="trama-card" data-reveal>
        <span class="card-num">I</span>
        <h3>Dal locale al globale</h3>
        <p>Festival, rassegne e incontri tematici — enogastronomia, turismo, design, ricerca, sostenibilità. Non capitoli separati: la stessa domanda, vista da angolazioni diverse.</p>
      </article>
      <article class="trama-card" data-reveal>
        <span class="card-num">II</span>
        <h3>Lab di co-creazione glocal</h3>
        <p>Progetti condivisi con università, imprese, istituzioni. Non per raccontare l'Italia al mondo, ma per costruirla insieme a chi la guarda da fuori.</p>
      </article>
      <article class="trama-card" data-reveal>
        <span class="card-num">III</span>
        <h3>Piattaforma per il territorio</h3>
        <p>Una rete che mette in relazione persone, luoghi, storie — la stessa rete di circa 300 realtà pubbliche e private che sostiene ogni edizione.</p>
      </article>
    </div>

    <!-- PLACEHOLDER PER PAOLO: il mosaico fotografico della brochure —
         tessere piccole e fitte, il brulicare del festival. -->
    <div class="mosaic" data-reveal aria-hidden="true">
      <div class="media-ph"><span>Foto</span></div>
      <div class="media-ph"><span>Foto</span></div>
      <div class="media-ph"><span>Foto</span></div>
      <div class="media-ph"><span>Foto</span></div>
      <div class="media-ph"><span>Foto</span></div>
      <div class="media-ph"><span>Foto</span></div>
    </div>
  </section>

  <section class="chapter" id="essenza">
    <h2 data-reveal>Essenza</h2>

    <div class="callout" data-reveal>
      <h3>Cos'è la tipicità?</h3>
      <p>Il ciauscolo è tipico delle Marche non perché qualcuno lo abbia deciso, ma perché qualcuno, prima di chiunque altro, ha interpretato in quella forma le condizioni di un territorio preciso — il clima, l'allevamento, i tempi di stagionatura di quella collina e non di un'altra.</p>
      <p>La tipicità non è un'etichetta che si mette su un prodotto già finito: è la traccia che il territorio lascia dentro le cose che genera. Per lo stesso motivo, una software house di Mumbai e una di Tolentino non lavoreranno mai allo stesso modo — non è una differenza di competenza, è una differenza di territorio.</p>
    </div>

    <div class="media-ph ph-right media-ph--tall" data-reveal><span>Foto · Il prodotto e la mano</span></div>

    <p data-reveal>Ma nessuna tipicità resta viva da sola. La pizza napoletana nasce da un incontro — il pomodoro arriva da un altro continente, prima di diventare più napoletano del napoletano stesso.</p>

    <p data-reveal>La cucina italiana è patrimonio immateriale Unesco non perché sia rimasta uguale nei secoli, ma per il motivo opposto: perché è un prodotto globale, mutato e mutevole, figlio delle dominazioni e delle aperture che hanno attraversato l'Italia.</p>

    <p class="keyline" data-reveal>Il locale non sopravvive isolandosi dal mondo — sopravvive attraversandolo.</p>

    <p data-reveal>È in questa tensione che si muove Tipicità: traiettorie e indigene, due parole che tirano in direzioni opposte e per questo si tengono in piedi a vicenda.</p>

    <div class="media-ph ph-left media-ph--tall" data-reveal><span>Foto · Fermo, i vicoli</span></div>

    <p data-reveal>Traiettoria è una parola aerea — rotte, mercati, il mondo che si muove in alto e per mare. Indigeno è una parola calda, quasi primordiale — l'istinto di un luogo, prima ancora che diventi racconto. Tipicità sta esattamente in mezzo: racconta il globale attraverso il locale.</p>

    <p data-reveal>Quando Tipicità nasce, nel 1993, l'enogastronomia non è ancora un argomento da prima serata. Il primo lavoro non è raccontare le Marche al mondo — è convincere i marchigiani stessi che quello che si produce sotto casa non vale meno di un marchio da supermercato.</p>

    <p data-reveal>Da lì, la consapevolezza cresce insieme all'ambizione del racconto: prima i territori (Tipicità MarcheTur, poi Tipicità Experience), poi la manualità che attraversa artigianato, moda, industria digitale — ovunque ci sia una relazione tra chi fa una cosa e il luogo in cui la fa (Art &amp; Genius). Dopo il 2020, il passo più grande: accogliere anche chi viene da fuori regione, perché un fenomeno si capisce solo per confronto.</p>

    <p class="keyline" data-reveal>Oggi Tipicità sta diventando qualcos'altro ancora — il festival delle traiettorie indigene.</p>

    <p data-reveal>I percorsi e le esperienze che raccontano la tipicità di oggi, non quella di trent'anni fa.</p>

    <div class="media-strip" data-reveal>
      <div class="media-ph"><span>Foto · Percorsi espositivi</span></div>
      <div class="media-ph"><span>Foto · Aree eventi</span></div>
      <div class="media-ph"><span>Foto · Fermo, il festival</span></div>
    </div>
  </section>

  <section class="chapter" id="motore">
    <h2 data-reveal>Motore</h2>

    <div class="motor-grid">
      <div class="motor-cell" data-reveal>
        <h3>Traiettorie</h3>
        <p>Il Made in Marche esce dai confini regionali: dai palchi di Fermo alle fiere di Dubai, New York, Tokyo — non vetrine isolate, tappe della stessa rotta.</p>
      </div>

      <div class="motor-cell" data-reveal>
        <h3>Carburante</h3>
        <p class="big-number">~300</p>
        <p>realtà pubbliche e private — enti, imprese, università — che co-progettano ogni edizione in partnership pubblico-privata.</p>
      </div>

      <div class="motor-cell" data-reveal>
        <h3>Impatto</h3>
        <p>Ogni edizione si converte in occasioni concrete: visibilità per i brand, accesso a mercati nazionali e internazionali, relazioni che restano attive oltre i tre giorni di festival.</p>
      </div>

      <div class="motor-cell" data-reveal>
        <h3>Ingranaggi</h3>
        <p>Nove temi attraversano ogni edizione:</p>
        <ul class="gear-chips">
          {gears.map((g) => <li>{g}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="chapter" id="tracce">
    <h2 data-reveal>Tracce</h2>
    <p data-reveal>Una rotta che si allunga edizione dopo edizione, non una serie di trasferte isolate.</p>

    <ol class="timeline">
      {timeline.map((t) => (
        <li class={t.key ? 'key' : ''} data-reveal>
          <span class="year">{t.year}</span>
          <span class="event">{t.text}</span>
        </li>
      ))}
    </ol>
  </section>
</BrandLayout>

<style is:global>
  /* Eco brochure: la barra dei capitoli su Tipicità è una banda teal
     piena — il wordmark bianco ci vive sopra, come in copertina. */
  .chapter-bar.v-tipicita {
    background: color-mix(in srgb, var(--brand-accent) 94%, black);
    border-color: transparent;
  }

  .chapter-bar.v-tipicita nav a {
    color: rgba(255, 255, 255, 0.82);
  }

  .chapter-bar.v-tipicita nav a:hover {
    color: #fff;
  }

  .chapter-bar.v-tipicita .bar-home {
    color: rgba(255, 255, 255, 0.55);
  }

  .chapter-bar.v-tipicita .bar-home:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  /* Capitoli col punto, come ".TRAMA" nella brochure. */
  main.brand-main.v-tipicita section.chapter > h2::before {
    content: '.';
    display: inline;
    font-family: inherit;
    font-size: 1em;
    font-weight: 700;
    letter-spacing: 0;
    color: var(--brand-accent);
    margin: 0 0.04em 0 0;
  }

  /* Aria: corpo più grande, interlinea generosa, più spazio tra i
     blocchi. La lettura deve essere una passeggiata, non una salita. */
  main.brand-main.v-tipicita {
    max-width: 820px;
  }

  main.brand-main.v-tipicita section.chapter {
    padding: 5rem 0;
    overflow: hidden;
  }

  main.brand-main.v-tipicita section.chapter > p,
  main.brand-main.v-tipicita .callout p {
    font-size: 1.06rem;
    line-height: 1.8;
    margin-bottom: 1.6em;
  }

  main.brand-main.v-tipicita section.chapter > h2 {
    margin-bottom: 1.2em;
  }
</style>

<style>
  /* --- Trama: tre schede ariose --- */
  .trama-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(215px, 1fr));
    gap: 1.2rem;
    margin: 0 0 2rem;
  }

  .trama-grid > :nth-child(2) { transition-delay: 0.12s; }
  .trama-grid > :nth-child(3) { transition-delay: 0.24s; }

  .trama-card {
    background: var(--bg-deep);
    padding: 1.8rem 1.5rem;
  }

  .trama-card .card-num {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: var(--brand-accent);
    margin-bottom: 0.7rem;
  }

  .trama-card h3 {
    font-size: 1.18rem;
    margin-bottom: 0.5rem;
  }

  .trama-card p {
    font-size: 0.94rem;
    line-height: 1.65;
    color: var(--text-dim);
    margin: 0;
  }

  /* Mosaico fotografico, come la colonna di tessere della brochure. */
  .mosaic {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 6px;
  }

  .mosaic .media-ph {
    aspect-ratio: 1;
    padding: 0.5rem;
  }

  .mosaic .media-ph span {
    font-size: 0.5rem;
  }

  @media (max-width: 640px) {
    .mosaic {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* --- Essenza: callout con titolo, frasi-chiave, immagini nel testo --- */
  .callout {
    background: var(--brand-accent);
    padding: 2.2rem 2.4rem;
    margin: 0 0 2.4rem;
  }

  .callout h3 {
    color: #fff;
    font-size: 1.5rem;
    margin-bottom: 0.8em;
  }

  .callout p {
    color: rgba(255, 255, 255, 0.93);
  }

  .callout p:last-child {
    margin-bottom: 0;
  }

  .keyline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 3.4vw, 2.1rem);
    line-height: 1.32;
    color: var(--brand-accent);
    max-width: 22ch;
    margin: 2.6rem 0 !important;
    padding-left: 1.4rem;
    border-left: 3px solid var(--brand-accent);
  }

  .ph-right {
    float: right;
    width: min(44%, 300px);
    margin: 0.4rem 0 1.4rem 1.8rem;
  }

  .ph-left {
    float: left;
    width: min(44%, 300px);
    margin: 0.4rem 1.8rem 1.4rem 0;
  }

  @media (max-width: 680px) {
    .ph-right,
    .ph-left {
      float: none;
      width: 100%;
      margin: 1.4rem 0;
    }
  }

  /* --- Motore: quattro celle in griglia, respiro tra le colonne --- */
  .motor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.4rem 3rem;
  }

  .motor-cell h3 {
    font-size: 1.2rem;
    color: var(--brand-accent);
    margin-bottom: 0.5rem;
  }

  .motor-cell p {
    font-size: 0.96rem;
    line-height: 1.7;
    color: var(--text-dim);
    margin-bottom: 0.6em;
  }

  .big-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    font-weight: 600;
    color: var(--brand-accent);
    line-height: 1;
    margin: 0.2em 0 0.25em !important;
  }

  .gear-chips {
    list-style: none;
    margin: 0.6rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .gear-chips li {
    font-family: 'Manrope', sans-serif;
    font-size: 0.76rem;
    letter-spacing: 0.02em;
    color: var(--brand-accent);
    border: 1px solid color-mix(in srgb, var(--brand-accent) 45%, transparent);
    border-radius: 999px;
    padding: 0.34rem 0.85rem;
    background: color-mix(in srgb, var(--brand-accent) 6%, transparent);
  }

  /* --- Tracce: timeline --- */
  .timeline {
    list-style: none;
    margin: 2.4rem 0 0;
    padding: 0;
    border-left: 2px solid var(--hairline);
  }

  .timeline li {
    position: relative;
    padding: 0 0 1.8rem 1.9rem;
  }

  .timeline li::before {
    content: '';
    position: absolute;
    left: -8px;
    top: 0.42em;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--brand-accent);
  }

  .timeline li.key::before {
    background: #a52257;
  }

  .timeline .year {
    display: block;
    font-family: 'Manrope', sans-serif;
    font-weight: 500;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: var(--text-soft);
    margin-bottom: 0.15rem;
  }

  .timeline li.key .year {
    color: #a52257;
  }

  .timeline .event {
    display: block;
    font-size: 0.94rem;
    line-height: 1.6;
    color: var(--text-dim);
    max-width: 56ch;
  }
</style>
