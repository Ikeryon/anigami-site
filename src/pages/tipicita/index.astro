---
import BrandLayout from '../../layouts/BrandLayout.astro';

// PAGINA-ECO DELLA BROCHURE TF27 (nota di Paolo, 10/07/2026):
// la landing riecheggia la brochure ufficiale — copertina come campo
// pieno teal con wordmark bianco (heroVariant="field"), interni su
// bianco luminoso, capitoli introdotti dal punto (".Trama" come
// ".TRAMA" della brochure), un box a campo pieno per la definizione
// di tipicità, e le Tracce come timeline con gli anni.
// I testi restano quelli lavorati insieme.
//
// ⚠️ DISCREPANZA DA RISOLVERE: la brochure fa partire la timeline dal
// 1991 ("Festival dei prodotti tipici delle Marche") e parla di 35ª
// edizione nel 2027; i testi che abbiamo scritto insieme dicono 1993.
// Qui in timeline seguo la brochure, nel testo resta 1993 — dimmi tu
// quale data è quella giusta e uniformo.

const chapters = [
  { id: 'trama', label: 'Trama' },
  { id: 'essenza', label: 'Essenza' },
  { id: 'motore', label: 'Motore' },
  { id: 'tracce', label: 'Tracce' },
];

// Date confermate da Paolo (10/07/2026): edizione 2027, 12-13-14 marzo.
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: 'Tipicità Festival',
  startDate: '2027-03-12',
  endDate: '2027-03-14',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: {
    '@type': 'Place',
    name: 'Fermo',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Fermo',
      addressRegion: 'Marche',
      addressCountry: 'IT',
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Imagina Srl Società Benefit',
    url: 'https://anigami.it',
  },
};

// Cromia dalla brochure: interni bianchi, teal ufficiale come accento.
const theme = {
  '--bg-void': '#fcfcfa',
  '--bg-deep': '#eef4f4',
  '--bg-mid': '#e2eded',
  '--text-soft': '#1e2a2c',
  '--text-dim': 'rgba(30, 42, 44, 0.68)',
  '--text-faint': 'rgba(30, 42, 44, 0.44)',
  '--hairline': 'rgba(3, 95, 106, 0.16)',
};

// Timeline delle Tracce — dati dalla brochure TF27.
const timeline = [
  { year: '1991', text: 'Festival dei prodotti tipici delle Marche — l’evento pionieristico', key: true },
  { year: '2011', text: 'Made in Marche Festival — turismo, moda e artigianato accanto all’enogastronomia', key: true },
  { year: '2015–16', text: 'Dubai, EAU — Italian Cuisine World Summit' },
  { year: '2017', text: 'Abu Dhabi, EAU — Italian Cuisine World Summit' },
  { year: '2018', text: 'New York, USA · Tirana e Valona, Albania' },
  { year: '2019', text: 'Ottawa e Montréal, Canada' },
  { year: '2022', text: 'Semplicemente "Festival" — ecosistema nazionale delle "micro-Italie" · EXPO2020 Dubai · Dar Es Salaam e Zanzibar, Tanzania', key: true },
  { year: '2023', text: 'Parigi, Francia — presentazione della candidatura Unesco della cucina italiana' },
  { year: '2024', text: 'Tokyo e Osaka, Giappone' },
  { year: '2025', text: 'EXPO2025 Osaka · Bahia Blanca, Buenos Aires e Ushuaia, Argentina' },
  { year: '2027', text: '35ª edizione — Fermo, 12–14 marzo', key: true },
];
---

<BrandLayout
  title="Tipicità Festival — Fermo, 12-14 marzo 2027"
  description="Tipicità Festival, Fermo, 12-14 marzo 2027: dal 1993 il festival delle traiettorie indigene tra enogastronomia, artigianato e cultura del territorio."
  accent="#035f6a"
  brandName="Tipicità Festival"
  chapters={chapters}
  structuredData={structuredData}
  logoSrc="/logos/tipicita.svg"
  kicker="Fermo · 12–14 marzo 2027"
  heroLine="Il festival delle traiettorie indigene. Racconta il globale attraverso il locale."
  theme={theme}
  heroVariant="field"
  variant="v-tipicita"
>
  <Fragment slot="practical">
    <span><strong>Quando</strong> 12–14 marzo 2027</span>
    <span><strong>Dove</strong> Fermo</span>
    <span><strong>Dal</strong> 1993</span>
  </Fragment>

  <section class="chapter" id="trama">
    <h2>Trama</h2>

    <h3>Dal locale al globale</h3>
    <p>Festival, rassegne e incontri tematici — enogastronomia, turismo, design, ricerca, sostenibilità. Non capitoli separati: la stessa domanda, vista da angolazioni diverse.</p>

    <h3>Lab di co-creazione glocal</h3>
    <p>Progetti condivisi con università, imprese, istituzioni. Non per raccontare l'Italia al mondo, ma per costruirla insieme a chi la guarda da fuori.</p>

    <h3>Piattaforma per lo sviluppo del territorio</h3>
    <p>Una rete che mette in relazione persone, luoghi, storie — la stessa rete di circa 300 realtà pubbliche e private che sostiene ogni edizione.</p>
  </section>

  <section class="chapter" id="essenza">
    <h2 data-reveal>Essenza</h2>

    <div class="callout" data-reveal>
      <p>Il ciauscolo è tipico delle Marche non perché qualcuno lo abbia deciso, ma perché qualcuno, prima di chiunque altro, ha interpretato in quella forma le condizioni di un territorio preciso — il clima, l'allevamento, i tempi di stagionatura di quella collina e non di un'altra. La tipicità non è un'etichetta che si mette su un prodotto già finito: è la traccia che il territorio lascia dentro le cose che genera. Per lo stesso motivo, una software house di Mumbai e una di Tolentino non lavoreranno mai allo stesso modo — non è una differenza di competenza, è una differenza di territorio.</p>
    </div>

    <p data-reveal>Ma nessuna tipicità resta viva da sola. La pizza napoletana nasce da un incontro — il pomodoro arriva da un altro continente, prima di diventare più napoletano del napoletano stesso. La cucina italiana è patrimonio immateriale Unesco non perché sia rimasta uguale nei secoli, ma per il motivo opposto: perché è un prodotto globale, mutato e mutevole, figlio delle dominazioni e delle aperture che hanno attraversato l'Italia. Il locale non sopravvive isolandosi dal mondo — sopravvive attraversandolo.</p>

    <p data-reveal>È in questa tensione che si muove Tipicità: traiettorie e indigene, due parole che tirano in direzioni opposte e per questo si tengono in piedi a vicenda. Traiettoria è una parola aerea — rotte, mercati, il mondo che si muove in alto e per mare. Indigeno è una parola calda, quasi primordiale — l'istinto di un luogo, prima ancora che diventi racconto. Tipicità sta esattamente in mezzo: racconta il globale attraverso il locale.</p>

    <p data-reveal>Quando Tipicità nasce, nel 1993, l'enogastronomia non è ancora un argomento da prima serata. Il primo lavoro non è raccontare le Marche al mondo — è convincere i marchigiani stessi che quello che si produce sotto casa non vale meno di un marchio da supermercato. Da lì, la consapevolezza cresce insieme all'ambizione del racconto: prima i territori (Tipicità MarcheTur, poi Tipicità Experience), poi la manualità che attraversa artigianato, moda, industria digitale — ovunque ci sia una relazione tra chi fa una cosa e il luogo in cui la fa (Art &amp; Genius). Dopo il 2020, il passo più grande: accogliere anche chi viene da fuori regione, perché un fenomeno si capisce solo per confronto.</p>

    <p data-reveal>Oggi Tipicità sta diventando qualcos'altro ancora — il festival delle traiettorie indigene: i percorsi e le esperienze che raccontano la tipicità di oggi, non quella di trent'anni fa.</p>

    <!-- PLACEHOLDER PER PAOLO: qui andranno le immagini reali del festival —
         nella brochure questo ruolo lo gioca il mosaico di foto della Trama. -->
    <div class="media-strip" data-reveal>
      <div class="media-ph"><span>Foto · Percorsi espositivi</span></div>
      <div class="media-ph"><span>Foto · Aree eventi</span></div>
      <div class="media-ph"><span>Foto · Fermo, il festival</span></div>
    </div>
  </section>

  <section class="chapter" id="motore">
    <h2>Motore</h2>

    <h3>Traiettorie</h3>
    <p>Il Made in Marche esce dai confini regionali: dai palchi di Fermo alle fiere di Dubai, New York, Tokyo — non vetrine isolate, tappe della stessa rotta.</p>

    <h3>Carburante</h3>
    <div class="numbers">
      <div class="stat"><strong>~300</strong><span>realtà pubbliche e private in rete</span></div>
    </div>
    <p>Una partnership pubblico-privata che oggi conta circa 300 realtà — enti, imprese, università — che co-progettano ogni edizione.</p>

    <h3>Impatto</h3>
    <p>Ogni edizione si converte in occasioni concrete: visibilità per i brand, accesso a mercati nazionali e internazionali, relazioni che restano attive oltre i tre giorni di festival.</p>

    <h3>Ingranaggi</h3>
    <p>Nove temi attraversano ogni edizione: sviluppo territoriale, biodiversità e sostenibilità, turismo esperienziale, patrimonio enogastronomico e innovazione, manifattura creativa e Made in Italy, economia circolare e transizione verde, cooperazione accademica e ricerca, cultura digitale e comunità intelligenti, giovani e competenze per il futuro.</p>
  </section>

  <section class="chapter" id="tracce">
    <h2>Tracce</h2>
    <p data-reveal>Una rotta che si allunga edizione dopo edizione, non una serie di trasferte isolate.</p>

    <ol class="timeline">
      {timeline.map((t) => (
        <li class={t.key ? 'key' : ''} data-reveal>
          <span class="year">{t.year}</span>
          <span class="event">{t.text}</span>
        </li>
      ))}
    </ol>
  </section>
</BrandLayout>

<style is:global>
  /* Eco brochure: la barra dei capitoli su Tipicità è una banda teal
     piena — il wordmark bianco ci vive sopra, come in copertina. */
  .chapter-bar.v-tipicita {
    background: color-mix(in srgb, var(--brand-accent) 94%, black);
    border-color: transparent;
  }

  .chapter-bar.v-tipicita nav a {
    color: rgba(255, 255, 255, 0.82);
  }

  .chapter-bar.v-tipicita nav a:hover {
    color: #fff;
  }

  .chapter-bar.v-tipicita .bar-home {
    color: rgba(255, 255, 255, 0.55);
  }

  .chapter-bar.v-tipicita .bar-home:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  /* Capitoli col punto, come ".TRAMA" nella brochure: al posto del
     numero, il punto nel teal del marchio. */
  main.brand-main.v-tipicita section.chapter > h2::before {
    content: '.';
    display: inline;
    font-family: inherit;
    font-size: 1em;
    font-weight: 700;
    letter-spacing: 0;
    color: var(--brand-accent);
    margin: 0 0.04em 0 0;
  }
</style>

<style>
  /* Box a campo pieno per la definizione — eco del "Cos'è la
     Tipicità?" della brochure: teal pieno, testo bianco. */
  .callout {
    background: var(--brand-accent);
    padding: 1.8rem 2rem;
    margin: 0 0 1.6rem;
  }

  .callout p {
    color: rgba(255, 255, 255, 0.94);
    margin: 0;
  }

  /* Timeline delle Tracce — gli anni in colonna, i punti pieni,
     i momenti-chiave marcati, come nella brochure. */
  .timeline {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    border-left: 2px solid var(--hairline);
  }

  .timeline li {
    position: relative;
    padding: 0 0 1.6rem 1.8rem;
  }

  .timeline li::before {
    content: '';
    position: absolute;
    left: -8px;
    top: 0.42em;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--brand-accent);
  }

  .timeline li.key::before {
    background: #a52257;
  }

  .timeline .year {
    display: block;
    font-family: 'Manrope', sans-serif;
    font-weight: 500;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: var(--text-soft);
    margin-bottom: 0.15rem;
  }

  .timeline li.key .year {
    color: #a52257;
  }

  .timeline .event {
    display: block;
    font-size: 0.92rem;
    color: var(--text-dim);
    max-width: 56ch;
  }
</style>
